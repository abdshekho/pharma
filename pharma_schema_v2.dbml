// ===== ENUMS =====

Enum user_roles {
  company
  doctor
  pharmacist
  distributor
  representative
  admin
}

Enum user_status {
  pending
  active
  suspended
}

Enum dosage_forms {
  tablet
  capsule
  syrup
  injection
  cream
  ointment
  drop
  inhaler
}

Enum pack_units {
  tablet
  capsule
  ml
  syringe
  vial
  ampoule
}

Enum package_types {
  box
  bottle
  strip
  tube
  vial_pack
}

Enum product_status {
  draft
  active
  inactive
}

Enum promotion_type {
  percentage
  buyXgetY
}

Enum promotion_level {
  distributor
  pharmacist
}

Enum promotion_target_type {
  all
  doctors
  pharmacists
}

Enum company_distributor_status {
  active
  inactive
}

Enum order_status {
  pending
  approved
  in_delivery
  delivered
  cancelled
  rejected
}

Enum payment_method {
  cod
  bank_transfer
}

Enum sample_request_status {
  pending
  approved
  rejected
  delivered
}

Enum inventory_movement_types {
  in
  out
  adjustment
}

Enum notification_related_types {
  order
  product
  sample_request
  promotion
  user
}

// ===== USERS =====

Table users {
  id              uuid         [pk, default: `uuid_generate_v4()`]
  email           varchar(255) [unique, not null]
  phone           varchar(20)  [unique]
  password_hash   varchar(255) [not null]
  role            user_roles   [not null]
  status          user_status  [not null, default: 'pending']
  full_name       varchar(150)
  avatar_url      varchar(500)
  city_id         uuid         [ref: > cities.id]
  email_verified_at timestamp
  last_login_at   timestamp
  created_at      timestamp    [not null, default: `now()`]
  updated_at      timestamp    [not null, default: `now()`]
}

// ===== LOCATIONS =====

Table cities {
  id           uuid        [pk, default: `uuid_generate_v4()`]
  name_ar      varchar(100) [not null]
  name_en      varchar(100)
  country_code char(3)     [not null, default: 'DAM']
  is_active    boolean     [not null, default: true]
  created_at   timestamp   [not null, default: `now()`]
}

// ===== PROFILES =====

Table company_profiles {
  id                      uuid         [pk, default: `uuid_generate_v4()`]
  user_id                 uuid         [unique, not null, ref: > users.id]
  company_name            varchar(200) [not null]
  commercial_reg_no       varchar(50)  [not null]
  health_ministry_license varchar(50)  [not null]
  logo_url                varchar(500)
  website                 varchar(500)
  description             text
  verified_at             timestamp
  verified_by             uuid         [ref: > users.id]
  created_at              timestamp    [not null, default: `now()`]
}

Table doctor_profiles {
  id               uuid         [pk, default: `uuid_generate_v4()`]
  user_id          uuid         [unique, not null, ref: > users.id]
  license_number   varchar(50)  [unique, not null]
  specialization_id uuid        [ref: > specializations.id]
  hospital_name    varchar(200)
  license_doc_url  varchar(500) [not null]
  verified_by      uuid         [ref: > users.id]
  verified_at      timestamp
  created_at       timestamp    [not null, default: `now()`]
}

Table pharmacist_profiles {
  id                  uuid         [pk, default: `uuid_generate_v4()`]
  user_id             uuid         [unique, not null, ref: > users.id]
  pharmacy_license_no varchar(50)  [unique, not null]
  pharmacy_name       varchar(200) [not null]
  commercial_reg_no   varchar(50)
  address             text         [not null]
  license_doc_url     varchar(500)
  verified_at         timestamp
  verified_by         uuid         [ref: > users.id]
  created_at          timestamp    [not null, default: `now()`]
}

Table distributor_profiles {
  id              uuid         [pk, default: `uuid_generate_v4()`]
  user_id         uuid         [unique, not null, ref: > users.id]
  company_name    varchar(200) [not null]
  license_doc_url varchar(500)
  verified_at     timestamp
  verified_by     uuid         [ref: > users.id]
  created_at      timestamp    [not null, default: `now()`]
}

// المندوب العلمي — تابع لشركة معينة ومسؤول عن مدينة
Table representative_profiles {
  id          uuid      [pk, default: `uuid_generate_v4()`]
  user_id     uuid      [unique, not null, ref: > users.id]
  company_id  uuid      [not null, ref: > company_profiles.id]
  city_id     uuid      [not null, ref: > cities.id]
  verified_at timestamp
  verified_by uuid      [ref: > users.id]
  created_at  timestamp [not null, default: `now()`]
}

// ===== SPECIALIZATIONS & CATEGORIES =====

Table specializations {
  id          uuid         [pk, default: `uuid_generate_v4()`]
  parent_id   uuid         [ref: > specializations.id]
  name_ar     varchar(100) [not null]
  name_en     varchar(100)
  description text
  is_active   boolean      [not null, default: true]
}

Table categories {
  id        uuid         [pk, default: `uuid_generate_v4()`]
  parent_id uuid         [ref: > categories.id]
  name_ar   varchar(100) [not null]
  name_en   varchar(100)
  icon      varchar(255)
  is_active boolean      [not null, default: true]
}

// ===== DRUG GROUPS =====

Table drug_groups {
  id          uuid         [pk, default: `uuid_generate_v4()`]
  name_ar     varchar(200) [unique, not null]
  name_en     varchar(200)
  description text
  is_active   boolean      [not null, default: true]
  created_at  timestamp    [not null, default: `now()`]
  updated_at  timestamp    [not null, default: `now()`]
}

Table drug_group_categories {
  drug_group_id uuid [not null, ref: > drug_groups.id]
  category_id   uuid [not null, ref: > categories.id]

  indexes {
    (drug_group_id, category_id) [pk]
  }
}

// ===== PRODUCTS =====

// dosage_form   → شكل الدواء
// pack_size     → عدد الوحدات (20 tablet - 100 ml)
// pack_unit     → نوع الوحدة  (ml - tablet)
// package_type  → نوع العبوة  (علبة - زجاجة)

Table products {
  id                 uuid          [pk, default: `uuid_generate_v4()`]
  company_id         uuid          [not null, ref: > company_profiles.id]
  name_ar            varchar(200)  [not null]
  name_en            varchar(200)
  dosage_form        dosage_forms
  pack_size          int
  pack_unit          pack_units
  package_type       package_types
  barcode            varchar(100)  [unique]
  strength           varchar(50)   [note: 'مثال: 500mg أو 250mg/5ml']
  usage_instructions text
  price              decimal(10,2) [not null, note: 'CHECK price >= 0']
  status             product_status [not null, default: 'draft']
  image_url          varchar(500)
  brochure_url       varchar(500)  [note: 'PDF file']
  created_at         timestamp     [not null, default: `now()`]
  updated_at         timestamp     [not null, default: `now()`]
}

Table product_drug_groups {
  product_id    uuid [not null, ref: > products.id]
  drug_group_id uuid [not null, ref: > drug_groups.id]

  indexes {
    (product_id, drug_group_id) [pk]
  }
}

Table product_target_specializations {
  id                uuid [pk, default: `uuid_generate_v4()`]
  drug_group_id     uuid [not null, ref: > drug_groups.id]
  specialization_id uuid [not null, ref: > specializations.id]

  indexes {
    (drug_group_id, specialization_id) [unique]
  }
}

// ===== COMPANY DISTRIBUTORS =====
// الشركة تعين موزعاً لكل مدينة

Table company_distributors {
  id             uuid                      [pk, default: `uuid_generate_v4()`]
  company_id     uuid                      [not null, ref: > company_profiles.id]
  distributor_id uuid                      [not null, ref: > distributor_profiles.id]
  city_id        uuid                      [not null, ref: > cities.id]
  status         company_distributor_status [not null, default: 'active']
  assigned_at    timestamp                 [not null, default: `now()`]

  indexes {
    (company_id, distributor_id, city_id) [unique]
  }
}

// ===== PROMOTIONS =====

// type  → percentage: خصم بنسبة مئوية | buyXgetY: اشتري X خذ Y مجاناً
// level → distributor: العرض للموزع من الشركة | pharmacist: العرض للصيدلاني
// distributor_id    → null لو الشركة أنشأته، موجود لو الموزع أنشأه
// parent_promotion_id → لو الموزع نسخ عرض الشركة وعدّل عليه

Table promotions {
  id                  uuid                  [pk, default: `uuid_generate_v4()`]
  company_id          uuid                  [not null, ref: > company_profiles.id]
  distributor_id      uuid                  [ref: > distributor_profiles.id]
  parent_promotion_id uuid                  [ref: > promotions.id]
  title               varchar(200)          [not null]
  description         text
  type                promotion_type        [not null, default: 'percentage']
  level               promotion_level       [not null, default: 'pharmacist']
  starts_at           timestamp             [not null]
  ends_at             timestamp             [not null]
  target_type         promotion_target_type [not null, default: 'all']
  image_url           varchar(500)
  is_active           boolean               [not null, default: false]
  created_at          timestamp             [not null, default: `now()`]
}

// للعروض من نوع percentage — خصم مختلف لكل منتج
Table promotion_products {
  id               uuid         [pk, default: `uuid_generate_v4()`]
  promotion_id     uuid         [not null, ref: > promotions.id]
  product_id       uuid         [not null, ref: > products.id]
  discount_percent decimal(5,2) [not null, note: 'CHECK 0-100']

  indexes {
    (promotion_id, product_id) [unique]
  }
}

// للعروض من نوع buyXgetY — اشتري X من منتج معين خذ Y من منتج آخر مجاناً
Table promotion_buyxgety {
  id              uuid [pk, default: `uuid_generate_v4()`]
  promotion_id    uuid [unique, not null, ref: > promotions.id]
  buy_product_id  uuid [not null, ref: > products.id]
  buy_quantity    int  [not null]
  free_product_id uuid [not null, ref: > products.id]
  free_quantity   int  [not null]
}

// ===== SAMPLE QUOTAS =====
// الشركة تحدد كم عينة يحق للطبيب أن يطلب لكل منتج

Table sample_quotas {
  id             uuid    [pk, default: `uuid_generate_v4()`]
  company_id     uuid    [not null, ref: > company_profiles.id]
  product_id     uuid    [not null, ref: > products.id]
  max_per_doctor int     [not null, default: 1,  note: 'الحد الشهري']
  cooldown_days  int     [not null, default: 30, note: 'أيام الانتظار بين الطلبات']
  is_active      boolean [not null, default: true]
  created_at     timestamp [not null, default: `now()`]

  indexes {
    (company_id, product_id) [unique]
  }
}

// ===== ORDERS =====
// الصيدلاني يطلب من شركة معينة — يتعين الموزع تلقائياً بناءً على مدينة الصيدلاني

Table orders {
  id               uuid          [pk, default: `uuid_generate_v4()`]
  order_number     varchar(20)   [unique, not null, note: 'ORD-2025-00001']
  pharmacist_id    uuid          [not null, ref: > pharmacist_profiles.id]
  company_id       uuid          [not null, ref: > company_profiles.id]
  distributor_id   uuid          [ref: > distributor_profiles.id, note: 'Auto-assigned by city']
  city_id          uuid          [not null, ref: > cities.id]
  status           order_status  [not null, default: 'pending']
  total_amount     decimal(10,2) [not null, default: 0]
  payment_method   payment_method [not null, default: 'cod']
  delivery_address text          [not null]
  notes            text
  rejection_reason text
  approved_at      timestamp
  delivered_at     timestamp
  created_at       timestamp     [not null, default: `now()`]
  updated_at       timestamp     [not null, default: `now()`]

  note: 'status flow: pending→approved→in_delivery→delivered | pending→rejected | pending→cancelled'
}

Table order_items {
  id                   uuid          [pk, default: `uuid_generate_v4()`]
  order_id             uuid          [not null, ref: > orders.id]
  product_id           uuid          [not null, ref: > products.id]
  product_name         varchar(200)
  quantity             int           [not null, note: 'CHECK > 0']
  unit_price           decimal(10,2) [not null, note: 'سعر وقت الطلب']
  promotion_product_id uuid          [ref: > promotion_products.id]
  discount_amount      decimal(10,2) [not null, default: 0]
  subtotal             decimal(10,2) [note: 'Generated: qty * price - discount']
}

// ===== SAMPLE REQUESTS =====
// الطبيب يطلب عينة — يتعين المندوب تلقائياً بناءً على مدينة الطبيب

Table sample_requests {
  id                 uuid                  [pk, default: `uuid_generate_v4()`]
  doctor_id          uuid                  [not null, ref: > doctor_profiles.id]
  product_id         uuid                  [not null, ref: > products.id]
  company_id         uuid                  [not null, ref: > company_profiles.id]
  representative_id  uuid                  [ref: > representative_profiles.id, note: 'Auto-assigned by city']
  status             sample_request_status [not null, default: 'pending']
  quantity           int                   [not null, default: 1]
  delivery_address   text                  [not null]
  rejection_reason   text
  approved_at        timestamp
  delivered_at       timestamp
  created_at         timestamp             [not null, default: `now()`]
  updated_at         timestamp             [not null, default: `now()`]

  note: 'status flow: pending→approved→delivered | pending→rejected(company) | pending→rejected(doctor=cancel)'
}

// ===== INVENTORY =====

Table distributor_inventory {
  id                  uuid      [pk, default: `uuid_generate_v4()`]
  distributor_id      uuid      [not null, ref: > distributor_profiles.id]
  product_id          uuid      [not null, ref: > products.id]
  quantity_available  int       [not null, default: 0, note: 'CHECK >= 0']
  low_stock_threshold int       [not null, default: 10, note: 'تنبيه عند النزول عن هذا الحد']
  last_updated        timestamp [not null, default: `now()`]

  indexes {
    (distributor_id, product_id) [unique]
  }
}

Table inventory_movements {
  id             uuid                    [pk, default: `uuid_generate_v4()`]
  distributor_id uuid                    [ref: > distributor_profiles.id]
  product_id     uuid                    [ref: > products.id]
  type           inventory_movement_types [not null]
  quantity       int                     [not null]
  reference_id   uuid                    [note: 'order_id لو out | company_profile_id لو in']
  created_by     uuid                    [ref: > users.id]
  created_at     timestamp               [not null, default: `now()`]
}

// ===== COMMUNICATION =====

Table messages {
  id                 uuid      [pk, default: `uuid_generate_v4()`]
  conversation_id    uuid      [note: 'لتجميع الرسائل بمحادثة واحدة']
  parent_message_id  uuid      [ref: > messages.id, note: 'للردود']
  sender_id          uuid      [not null, ref: > users.id]
  receiver_id        uuid      [not null, ref: > users.id]
  related_product_id uuid      [ref: > products.id]
  body               text      [not null]
  attachment_url     varchar(500)
  read_at            timestamp
  created_at         timestamp [not null, default: `now()`]

  indexes {
    (conversation_id)
    (sender_id)
    (receiver_id)
  }
}

Table notifications {
  id           uuid                      [pk, default: `uuid_generate_v4()`]
  user_id      uuid                      [not null, ref: > users.id]
  type         varchar(50)               [not null, note: 'new_product|order_update|sample_update|new_offer|account_status|low_stock']
  title        varchar(200)              [not null]
  body         text
  related_id   uuid                      [note: 'Polymorphic reference']
  related_type notification_related_types
  read_at      timestamp
  created_at   timestamp                 [not null, default: `now()`]

  indexes {
    (user_id, read_at)
  }
}

// ===== AUDIT =====

Table audit_logs {
  id          uuid         [pk, default: `uuid_generate_v4()`]
  user_id     uuid         [ref: > users.id]
  action      varchar(100) [not null, note: 'e.g. order.created, user.verified']
  entity_type varchar(50)
  entity_id   uuid
  old_data    jsonb
  new_data    jsonb
  ip_address  varchar(45)
  user_agent  text
  created_at  timestamp    [not null, default: `now()`]
}

// ===== FLOW SUMMARY =====
// orders:         pharmacist → create → auto-assign distributor by city → distributor approve/reject → in_delivery → delivered
// sample_requests: doctor → create → auto-assign representative by city → company approve/reject → representative deliver
// inventory:      distributor add stock (in) → order delivered (out) → manual adjustment
// promotions:     company create (percentage|buyXgetY) → distributor can clone & modify for pharmacists
